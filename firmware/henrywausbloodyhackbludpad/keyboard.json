{
    "manufacturer": "HenryWauzivuff",
    
    "keyboard_name": "henrywausbloodyhackbludpad",
    
    "maintainer": "HenryWauzivuff",
    
    "bootloader": "rp2040",
    
    "diode_direction": "COL2ROW",
    
    "features": {
        "rgblight" : true,
        "bootmagic": true,
        "extrakey": true,
        "mousekey": true,
        "nkro": true,
        "encoder" : true
    },
    
    "matrix_pins": {
        "direct": [
            ["GP1", "GP2", "GP4", "GP3", "GP28"]
        ]
    },
    
    "processor": "RP2040",
    
    "url": "https://henryWauzivuff.github.io",
    
    "usb": {
        "device_version": "1.0.0",
        "pid": "0x2040",
        "vid": "0xFEED"
    },
    
