        "pin": "GP0",
        "driver": "vendor"
    },

    "rgblight": {
        "led_count": 4
    },

    "encoder": {
        "rotary": [
        { "pin_a": "GP27", "pin_b": "GP26" }
        ]
    },

    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                
                {"matrix": [0, 1], "x": 0, "y": 1},
                
                {"matrix": [0, 2], "x": 0, "y": 2},
                
                {"matrix": [0, 3], "x": 0, "y": 3},
                
                {"matrix": [1, 2], "x": 0, "y": 4}
            ]
        }
    }
}